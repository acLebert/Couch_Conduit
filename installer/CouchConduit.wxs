<?xml version="1.0" encoding="UTF-8"?>
<!--
  Couch Conduit — WiX v4 MSI Installer
  =====================================
  Build with:  wix build installer\CouchConduit.wxs -o dist\CouchConduit-0.1.0-x64.msi
  Requires:    WiX Toolset v4+ (dotnet tool install --global wix)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Couch Conduit"
           Version="0.1.0"
           Manufacturer="Couch Conduit Contributors"
           UpgradeCode="7e3a0c21-b5f4-4d9a-a8e7-cc2d1f8b3e6a"
           InstallerVersion="500"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Couch Conduit is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Install directory -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Couch Conduit">
        <Directory Id="DocFolder" Name="doc" />
      </Directory>
    </StandardDirectory>

    <!-- Features -->
    <Feature Id="HostFeature" Title="Host" Description="Stream sender (run on the gaming PC)" Level="1">
      <ComponentGroupRef Id="HostComponents" />
    </Feature>

    <Feature Id="ClientFeature" Title="Client" Description="Stream viewer (run on the couch PC)" Level="1">
      <ComponentGroupRef Id="ClientComponents" />
    </Feature>

    <Feature Id="RuntimeFeature" Title="FFmpeg Runtime" Description="Required FFmpeg DLLs" Level="1">
      <ComponentGroupRef Id="FFmpegComponents" />
    </Feature>

    <Feature Id="DocsFeature" Title="Documentation" Description="README, LICENSE" Level="1">
      <ComponentGroupRef Id="DocComponents" />
    </Feature>

    <!-- Start Menu shortcuts -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Couch Conduit" />
    </StandardDirectory>

  </Package>

  <!-- ─── Component Groups ─────────────────────────────────────── -->

  <Fragment>
    <ComponentGroup Id="HostComponents" Directory="INSTALLFOLDER">
      <Component Id="HostExe" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000001">
        <File Id="cc_host.exe" Source="..\build\src\host\Release\cc_host.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ClientComponents" Directory="INSTALLFOLDER">
      <Component Id="ClientExe" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000002">
        <File Id="cc_client.exe" Source="..\build\src\client\Release\cc_client.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="FFmpegComponents" Directory="INSTALLFOLDER">
      <Component Id="avcodec" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000010">
        <File Id="avcodec62.dll" Source="..\third_party\ffmpeg\bin\avcodec-62.dll" KeyPath="yes" />
      </Component>
      <Component Id="avutil" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000011">
        <File Id="avutil60.dll" Source="..\third_party\ffmpeg\bin\avutil-60.dll" KeyPath="yes" />
      </Component>
      <Component Id="swresample" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000012">
        <File Id="swresample5.dll" Source="..\third_party\ffmpeg\bin\swresample-5.dll" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="DocComponents" Directory="DocFolder">
      <Component Id="Readme" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000020">
        <File Id="README.md" Source="..\README.md" KeyPath="yes" />
      </Component>
      <Component Id="License" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000021">
        <File Id="LICENSE" Source="..\LICENSE" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Start Menu -->
  <Fragment>
    <ComponentGroup Id="Shortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="HostShortcut" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000030">
        <Shortcut Id="HostStartMenuShortcut"
                  Name="Couch Conduit Host"
                  Target="[INSTALLFOLDER]cc_host.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\CouchConduit" Name="HostShortcut" Type="integer" Value="1" KeyPath="yes" />
        <RemoveFolder Id="CleanUpHostShortcut" Directory="ApplicationProgramsFolder" On="uninstall" />
      </Component>
      <Component Id="ClientShortcut" Guid="A1B2C3D4-E5F6-4789-ABCD-000000000031">
        <Shortcut Id="ClientStartMenuShortcut"
                  Name="Couch Conduit Client"
                  Target="[INSTALLFOLDER]cc_client.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\CouchConduit" Name="ClientShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
